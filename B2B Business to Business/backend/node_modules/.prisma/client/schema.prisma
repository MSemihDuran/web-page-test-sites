datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  password             String
  name                 String
  companyName          String?
  phone                String?
  logoUrl              String?
  about                String?
  pendingEmail         String?
  pendingPhone         String?
  twoFactorEnabled     Boolean        @default(false)
  avatarUrl            String?
  companyEmail         String?
  companyPhone         String?
  companyEmailVerified Boolean        @default(false)
  companyPhoneVerified Boolean        @default(false)
  role                 String
  createdAt            DateTime       @default(now())
  products             Product[]      @relation("UserProducts")
  buyerQuotes          QuoteRequest[] @relation("BuyerQuotes")
  sellerQuotes         QuoteRequest[] @relation("SellerQuotes")
  messages             QuoteMessage[] @relation("UserMessages")
}

model Product {
  id          Int                 @id @default(autoincrement())
  title       String
  description String
  category    String
  dimensions  String?
  color       String?
  imageUrl    String?
  isActive    Boolean             @default(true)
  sellerId    Int
  seller      User                @relation("UserProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  quotes      QuoteRequest[]
  colorImages ProductColorImage[]
  createdAt   DateTime            @default(now())
}

model ProductColorImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  imageUrl  String
}

model QuoteRequest {
  id             Int            @id @default(autoincrement())
  productId      Int
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId        Int
  buyer          User           @relation("BuyerQuotes", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId       Int
  seller         User           @relation("SellerQuotes", fields: [sellerId], references: [id], onDelete: Cascade)
  status         String
  proposedPrice  Float?
  lastProposerId Int?
  notes          String?
  quantity       Int            @default(1)
  color          String?
  currency       String         @default("TRY")
  vatRate        Float          @default(20.0)
  trackingStage  String         @default("RECEIVED")
  messages       QuoteMessage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model QuoteMessage {
  id        Int          @id @default(autoincrement())
  quoteId   Int
  quote     QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User         @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime     @default(now())
}
